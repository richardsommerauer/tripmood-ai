# TripMood AI — environment variables
# The app works WITHOUT a key (built-in demo/mock plan). Set this for live AI.

# Your Anthropic (Claude) API key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Optional: which Claude model to use.
# Default is claude-opus-4-8 (most capable). For a cheaper/faster demo use:
#   ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MODEL=claude-opus-4-8
