<% content_for :title, "Trips · TripMood AI" %>
<div class="container py-4" style="max-width: 960px;">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
      <h1 class="mb-1">Day plans</h1>
      <p class="tm-ink-soft mb-0">Browse plans matched to a mood — or build your own.</p>
    </div>
    <%= link_to new_trip_path, class: "btn btn-primary" do %>
      <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Plan my day
    <% end %>
  </div>

  <% if @trips.any? %>
    <div class="row g-3">
      <% @trips.each do |trip| %>
        <div class="col-md-4">
          <%= link_to trip, class: "text-decoration-none" do %>
            <div class="tm-card trip-card p-4">
              <div class="d-flex align-items-center gap-3 mb-2">
                <span class="trip-emoji"><i class="<%= trip_emoji(trip) %>"></i></span>
                <span class="tm-badge tm-badge-mood"><%= trip.mood %></span>
              </div>
              <h2 class="h5 mb-1"><%= trip.title.presence || "#{trip.city} day" %></h2>
              <p class="tm-ink-soft small mb-2"><%= truncate(trip.summary, length: 90) %></p>
              <div class="d-flex gap-2 small tm-ink-soft">
                <span><i class="fa-solid fa-location-dot me-1"></i><%= trip.city %></span>
                <span><i class="fa-solid fa-clock me-1"></i><%= trip.duration %></span>
                <span><i class="fa-solid fa-wallet me-1"></i><%= trip.budget %></span>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="tm-card p-5 text-center">
      <p class="fs-5 mb-3">No day plans yet.</p>
      <%= link_to "Plan the first one", new_trip_path, class: "btn btn-primary btn-lg" %>
    </div>
  <% end %>
</div>
