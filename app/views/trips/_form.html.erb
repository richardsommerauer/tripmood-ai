<%= simple_form_for @trip, html: { class: "trip-form" } do |f| %>
  <% if @trip.errors.any? %>
    <div class="alert alert-warning">
      <strong><%= pluralize(@trip.errors.count, "thing") %> to fix:</strong>
      <ul class="mb-0"><% @trip.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <div class="tm-card p-4 mb-3">
    <%= f.input :city, label: "City", placeholder: "e.g. Bangalore",
          input_html: { class: "form-control" } %>
  </div>

  <div class="tm-card p-4 mb-3">
    <%= f.input :duration, label: "Available time", as: :radio_buttons,
          collection: Trip::DURATIONS, item_wrapper_class: "form-check-inline" %>
  </div>

  <div class="tm-card p-4 mb-3">
    <%= f.input :budget, label: "Budget", as: :radio_buttons,
          collection: Trip::BUDGETS, item_wrapper_class: "form-check-inline" %>
    <%= f.input :energy, label: "Energy level", as: :radio_buttons,
          collection: Trip::ENERGIES, item_wrapper_class: "form-check-inline", wrapper_html: { class: "mt-3" } %>
    <%= f.input :travel_style, label: "Travel style", as: :radio_buttons,
          collection: Trip::STYLES, item_wrapper_class: "form-check-inline", wrapper_html: { class: "mt-3" } %>
  </div>

  <div class="tm-card p-4 mb-3">
    <%= f.input :mood, label: "Mood", as: :radio_buttons,
          collection: Trip::MOODS, item_wrapper_class: "form-check-inline" %>
  </div>

  <div class="tm-card p-4 mb-4">
    <%= f.input :interests, label: "Interests (pick any)", as: :check_boxes,
          collection: Trip::INTEREST_OPTIONS, item_wrapper_class: "form-check-inline" %>
  </div>

  <%= f.button :submit, submit_label, class: "btn btn-primary btn-lg w-100" %>
  <p class="text-center tm-ink-soft mt-2 small">
    <i class="fa-solid fa-shield-heart me-1"></i>Works as a demo even without an API key.
  </p>
<% end %>
