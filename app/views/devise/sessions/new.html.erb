<div class="container py-5" style="max-width: 440px;">
  <div class="tm-card p-4 p-md-5">
    <h1 class="h3 text-center mb-4">Welcome back</h1>
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= f.input :email, required: false, autofocus: true,
            input_html: { autocomplete: "email", class: "form-control" } %>
      <%= f.input :password, required: false,
            input_html: { autocomplete: "current-password", class: "form-control" } %>
      <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
      <%= f.button :submit, "Log in", class: "btn btn-primary w-100 mt-2" %>
    <% end %>
    <div class="text-center mt-3 small">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
