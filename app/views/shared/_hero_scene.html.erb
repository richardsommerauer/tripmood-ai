<div class="hero-scene" aria-hidden="true">
  <svg viewBox="0 0 400 240" preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#ffeed7"/><stop offset="1" stop-color="#f8dcb8"/>
      </linearGradient>
      <linearGradient id="water" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#f3d4a6"/><stop offset="1" stop-color="#e4ba83"/>
      </linearGradient>
      <radialGradient id="sun" cx="50%" cy="50%" r="50%">
        <stop offset="0" stop-color="#fff0d2"/><stop offset="60%" stop-color="#ffd89a"/><stop offset="100%" stop-color="#ffd89a" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <!-- sky + sun -->
    <rect width="400" height="240" fill="url(#sky)"/>
    <circle cx="150" cy="120" r="70" fill="url(#sun)"/>
    <circle cx="150" cy="120" r="30" fill="#ffe0a6"/>

    <!-- far skyline -->
    <g fill="#e9c79e" opacity=".85">
      <rect x="20" y="92" width="20" height="60"/><rect x="44" y="78" width="14" height="74"/>
      <rect x="300" y="84" width="20" height="68"/><rect x="324" y="96" width="16" height="56"/>
      <rect x="350" y="74" width="14" height="78"/>
    </g>
    <!-- domed parliament-style building (Bangalore vibe) -->
    <g fill="#dcab7c">
      <rect x="180" y="96" width="70" height="56"/>
      <path d="M198 96a17 12 0 0 1 34 0z"/>
      <rect x="212" y="74" width="6" height="14"/><circle cx="215" cy="72" r="3"/>
      <g fill="#cf9c6a"><rect x="186" y="104" width="4" height="48"/><rect x="198" y="104" width="4" height="48"/><rect x="210" y="104" width="4" height="48"/><rect x="222" y="104" width="4" height="48"/><rect x="234" y="104" width="4" height="48"/></g>
    </g>

    <!-- trees -->
    <g>
      <circle cx="276" cy="120" r="22" fill="#8fae6a"/><circle cx="296" cy="126" r="26" fill="#7e9d58"/><rect x="284" y="140" width="5" height="22" fill="#9b7b54"/>
      <circle cx="366" cy="118" r="24" fill="#85a35f"/>
    </g>

    <!-- café on the right -->
    <g>
      <rect x="330" y="120" width="70" height="60" fill="#d8a877"/>
      <rect x="330" y="120" width="70" height="10" fill="#cf6a2d"/>
      <g fill="#f3e3cf"><rect x="332" y="120" width="8" height="10"/><rect x="348" y="120" width="8" height="10"/><rect x="364" y="120" width="8" height="10"/><rect x="380" y="120" width="8" height="10"/></g>
      <rect x="344" y="138" width="20" height="26" fill="#bf8a55"/>
      <rect x="372" y="138" width="18" height="20" fill="#f1d9b0"/>
      <text x="365" y="116" font-family="Inter, sans-serif" font-size="7" font-weight="700" fill="#fff" text-anchor="middle">COFFEE</text>
    </g>

    <!-- water -->
    <rect y="152" width="400" height="88" fill="url(#water)"/>
    <ellipse cx="150" cy="165" rx="120" ry="6" fill="#fff" opacity=".30"/>
    <ellipse cx="210" cy="180" rx="150" ry="5" fill="#fff" opacity=".18"/>

    <!-- promenade -->
    <rect y="196" width="400" height="44" fill="#ecd9ba"/>
    <rect y="196" width="400" height="4" fill="#d9bd92"/>
    <!-- railing -->
    <g stroke="#c49a6a" stroke-width="2"><line x1="0" y1="200" x2="400" y2="200"/><line x1="40" y1="200" x2="40" y2="212"/><line x1="120" y1="200" x2="120" y2="212"/><line x1="300" y1="200" x2="300" y2="212"/><line x1="370" y1="200" x2="370" y2="212"/></g>
    <!-- lamp post -->
    <g fill="#8a6a45"><rect x="96" y="150" width="4" height="62"/><circle cx="98" cy="148" r="5" fill="#ffe0a6"/></g>
    <!-- planters -->
    <g><rect x="30" y="206" width="16" height="14" fill="#c77f4a"/><circle cx="34" cy="204" r="5" fill="#7e9d58"/><circle cx="42" cy="205" r="5" fill="#8fae6a"/>
       <rect x="250" y="208" width="14" height="12" fill="#c77f4a"/><circle cx="254" cy="206" r="4" fill="#7e9d58"/><circle cx="261" cy="207" r="4" fill="#8fae6a"/></g>

    <!-- traveler (from behind, hat + backpack) -->
    <g transform="translate(196,168)">
      <ellipse cx="0" cy="58" rx="14" ry="3" fill="#caa877" opacity=".5"/>
      <rect x="-7" y="30" width="6" height="26" fill="#6f5b46"/><rect x="1" y="30" width="6" height="26" fill="#6f5b46"/>
      <path d="M-9 14h18l3 18h-24z" fill="#7c6a52"/>
      <rect x="-8" y="16" width="16" height="18" rx="5" fill="#e0a93f"/>
      <circle cx="0" cy="8" r="6" fill="#c98f63"/>
      <path d="M-11 7a11 5 0 0 1 22 0z" fill="#d8b06a"/><ellipse cx="0" cy="3" rx="6" ry="5" fill="#cf9c5e"/>
    </g>

    <!-- birds -->
    <g stroke="#b98a5e" stroke-width="1.4" fill="none" opacity=".7"><path d="M250 60q4-4 8 0q4-4 8 0"/><path d="M270 50q3-3 6 0q3-3 6 0"/></g>
  </svg>
</div>
